rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Security rules for user account synchronizations
    match /users/{userId} {
      // Allow general read/write as this represents profile, study metrics, and student data
      allow read, write: if userId != null && userId.size() > 0 && userId.size() < 128;
    }
  }
}
