rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }

    match /exam_results/{resultId} {
      allow read, write: if true;
    }

    match /configs/{configId} {
      allow read, write: if true;
    }
  }
}
